# ─── Agora ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_AGORA_APP_ID=
NEXT_AGORA_APP_CERTIFICATE=
NEXT_PUBLIC_AGENT_UID=123456
NEXT_PUBLIC_LANDLORD_ID=default-landlord

# ─── Auth ─────────────────────────────────────────────────────────────────────
AUTH_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
USER_USERNAME=user
USER_PASSWORD=user123

# ─── Database ─────────────────────────────────────────────────────────────────
# Neon / Postgres (required for Vercel). Local SQLite is no longer supported.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# ─── OpenAI LLM (BYOK) ────────────────────────────────────────────────────────
# Required for the rental voice agent LLM
NEXT_LLM_API_KEY=

# ─── Azure TTS (BYOK) ─────────────────────────────────────────────────────────
NEXT_AZURE_TTS_KEY=
NEXT_AZURE_TTS_REGION=
NEXT_AZURE_TTS_VOICE_NAME=fil-PH-BlessicaNeural

# ─── Deepgram ASR (BYOK) ──────────────────────────────────────────────────────
NEXT_DEEPGRAM_API_KEY=

# ─── Agent behavior ───────────────────────────────────────────────────────────
NEXT_AGENT_GREETING=Hi po! Ako si Maria, rental assistant. Ano po ang gusto ninyong malaman?
